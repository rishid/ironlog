{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeDigest",
    ":automergeBranch",
  ],
  timezone: "America/New_York",
  semanticCommits: "enabled",
  dependencyDashboard: true,
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: [
    "prIgnoreNotification",
  ],
  rebaseWhen: "conflicted",
  prHourlyLimit: 10,
  prConcurrentLimit: 20,
  "github-actions": {
    enabled: true,
    automerge: true,
    automergeType: "branch",
    schedule: ["before 7am on monday"],
  },
  packageRules: [
    {
      description: "Auto-merge non-major npm updates",
      matchDatasources: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
      automergeType: "branch",
    },
    {
      description: "Group all non-major npm dependencies",
      matchDatasources: ["npm"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "all non-major dependencies",
      groupSlug: "all-minor-patch",
    },
    {
      description: "Enable auto-merge for Docker digest updates",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      automerge: true,
    },
    {
      description: "Pin digests for all Docker tags",
      matchDatasources: ["docker"],
      pinDigests: true,
    },
    {
      description: "Auto-merge non-major Docker updates",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
    },
    {
      description: "Create PRs for major updates (no auto-merge)",
      matchUpdateTypes: ["major"],
      automerge: false,
      addLabels: ["dep/major"],
    },
    {
      description: "Auto-merge GitHub Actions major updates",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["major"],
      automerge: true,
      automergeType: "branch",
    },
  ],
}
